# LifeRecompiled environment example
# Copy this file to .env and fill in values for your Firebase / Cloudinary setup.
# Do not commit real .env or .env.staging files.

# Firebase client config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary unsigned upload config
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Public app URL for Firebase Auth email action links
VITE_APP_URL=

# Support / feedback route
VITE_SUPPORT_EMAIL=
